    "format-disconnected": "σΑ•Σ Disconnected",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
    "tooltip-format": "{ifname}: {ipaddr}",
  },

  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15,
    },
    "format": "{icon} {capacity}%",
    "format-charging": "σΑ²³ {capacity}%",
    "format-plugged": "σΑöΞ {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["σΑ²é", "σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"],
  },

  "cpu": {
    //"format": "σΑç¦ {usage}%",
    "format": "<span color='#c4a7e7'>σΑç¦</span> {usage}%",
    "tooltip": true,
    "interval": 1,
  },

  "custom/gpu": {
  "exec": "$HOME/dotfiles/scripts/gpucheck.sh",
  "format": "<span color='#a7c080'>σΑç¦</span> {}",
  "return-type": "json",
  "interval": 1
  },

  "memory": {
