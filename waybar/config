{
  "layer": "top",
  "reload_style_on_change": true,
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
    "hyprland/window",
    "network",


  ],
  "modules-center": ["clock", "custom/weather", "tray"],
  "modules-right": [
    "backlight",
    "temperature",
    "cpu",
    "custom/gpu",
    "memory",
    "pulseaudio",
    "battery",
  ],

 "custom/launcher":{
      "format": "ο¨É ",
      "on-click": "fuzzel",
      "on-click-right": "killall fuzzel"
    },

  "hyprland/workspaces": {
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "on-scroll-down": "hyprctl dispatch workspace e+1",
    "persistent-workspaces": {
      "*": 0, // 5 workspaces by default on every monitor
    },
  },

  "clock": {
    //"on-click": "gsimplecal",
    "format": "<span color='#ffcb6b'>σΑΞî</span> {:%H:%M | <span color='#c4a7e7'>σΑÉ°</span> %A, %d %B}",
    //"format": "{:σΑÉ° %A, %d %B | σΑΞî %H:%M}",
    //"format-alt": "σΑÉ° {:%A, %d %B}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><big>{calendar}</big></tt>",
    "calendar": {
      "locale": "en_GB.UTF-8",
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#d3c6aa'><b>{}</b></span>",
        "days": "<span color='#e67e80'>{}</span>",
        "weeks": "<span color='#a7c080'><b>W{}</b></span>",
        "weekdays": "<span color='#7fbbb3'><b>{}</b></span>",
        "today": "<span color='#dbbc7f'><b><u>{}</u></b></span>",
      },
    },
  },

  "custom/weather": {
  "exec": "~/.config/hypr/scripts/weather.sh",
  "interval": 900,
  "format": "<span color='#c4a7e7'></span> {}",
  "tooltip": true
},


  "tray": {
    "icon-size": 18,
    "spacing": 5,
  },

  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["σΑÉû", "σΑÉü", "σΑÉ†"],
    "on-click": "brightnessctl set +5%",
    "on-click-right": "brightnessctl set 5%-",
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "σΑ²Α {volume}%",
    "format-bluetooth-muted": "σΑ²≤ {icon}",
    "format-muted": "σΑùü",
    "format-icons": {
      "headphone": "σΑ΄΄",
      "hands-free": "σΑΞΑ",
      "headset": "σΑ΄é",
      "phone": "σΑè≤",
      "portable": "σΑ³ù",
      "car": "σΑ³΄",
      "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"],
    },
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%",
  },

  "network": {
    "format-wifi": "σΑ•© {essid} {signalStrength}%",
