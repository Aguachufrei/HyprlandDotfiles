{
  "layer": "top",
  "reload_style_on_change": true,
  "modules-left": [
    "custom/launcher",
    "hyprland/workspaces",
//  "hyprland/window",
    "network",


  ],
  "modules-center": ["clock", /*"custom/weather",*/ "tray"],
  "modules-right": [
    "backlight",
    "temperature",
    "cpu",
    "custom/amd_gpu",
    "custom/nvidia_gpu",
    "memory",
    "pulseaudio",
    "battery",
  ],

 "custom/launcher":{
      "format": "´îâ ",
      "on-click": "rofi -show drun",
      "on-click-right": "killall rofi"
    },

  "hyprland/workspaces": {
    "on-click": "activate",
    "on-scroll-up": "hyprctl dispatch workspace e-1",
    "on-scroll-down": "hyprctl dispatch workspace e+1",
    "persistent-workspaces": {
      "*": 0, // 5 workspaces by default on every monitor
    },
  },

  "clock": {
    //"on-click": "gsimplecal",
    "format": "<span color='#ffcb6b'>¾░Ñö</span> {:%H:%M | <span color='#c4a7e7'>¾░â«</span> %A, %d %B}",
    //"format": "{:¾░â« %A, %d %B | ¾░Ñö %H:%M}",
    //"format-alt": "¾░â« {:%A, %d %B}",
    "tooltip-format": "<big>{:%Y %B}</big>\n<tt><big>{calendar}</big></tt>",
    "calendar": {
          "locale": "es_ES.UTF-8",
      "mode": "month",
      "mode-mon-col": 3,
      "weeks-pos": "right",
      "on-scroll": 1,
      "on-click-right": "mode",
      "format": {
        "months": "<span color='#d3c6aa'><b>{}</b></span>",
        "days": "<span color='#e67e80'>{}</span>",
        "weeks": "<span color='#a7c080'><b>W{}</b></span>",
        "weekdays": "<span color='#7fbbb3'><b>{}</b></span>",
        "today": "<span color='#dbbc7f'><b><u>{}</u></b></span>",
      },
    },
  },

  "tray": {
    "icon-size": 18,
    "spacing": 5,
  },

  "backlight": {
    "format": "{icon} {percent}%",
    "format-icons": ["¾░âŞ", "¾░âş", "¾░âá"],
    "on-click": "brightnessctl set +5%",
    "on-click-right": "brightnessctl set -5%",
    "on_scroll-up": "brightnessctl set +5%",
    "on_scroll-down": "brightnessctl set -5%",
  },

  "pulseaudio": {
    "format": "{icon} {volume}%",
    "format-bluetooth": "¾░é░ {volume}%",
    "format-bluetooth-muted": "¾░é▓ {icon}",
    "format-muted": "¾░Øş",
    "format-icons": {
      "headphone": "¾░ïï",
      "hands-free": "¾░Ñ░",
      "headset": "¾░ïÄ",
      "phone": "¾░Å▓",
      "portable": "¾░äØ",
      "car": "¾░äï",
      "default": ["¾░ò┐", "¾░ûÇ", "¾░ò¥"],
    },
    "on-click": "pavucontrol",
    "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-scroll-up": "pactl set-sink-volume @DEFAULT_SINK@ +2%",
    "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%",
  },

  "network": {
    "format-wifi": "¾░û® {essid} {signalStrength}%",
    //"format-ethernet": "¾░êÇ {ipaddr}",
    "format-ethernet": "<span color='#7CCD7F'>¾░êÇ</span> {ipaddr}",
    //"format-linked": "¾░êÇ {ifname} (No IP)",
    "format-disconnected": "¾░û¬ Disconnected",
    "format-alt": "{ifname}: {ipaddr}/{cidr}",
    "tooltip-format": "{ifname}: {ipaddr}",
  },

  "battery": {
    "states": {
      "good": 95,
      "warning": 30,
      "critical": 15,
    },
    "bat":"BAT0",
    "format": "{icon} {capacity}%",
    "format-charging": "¾░éä {capacity}%",
    "format-plugged": "¾░ÜÑ {capacity}%",
    "format-alt": "{icon} {time}",
    "format-icons": ["¾░éÄ", "¾░ü║", "¾░ü╗", "¾░ü╝", "¾░ü¢", "¾░ü¥", "¾░ü┐", "¾░éÇ", "¾░éü", "¾░éé", "¾░ü╣"],
  },

  "cpu": {
    //"format": "¾░ıø {usage}%",
    "format": "<span color='#c4a7e7'>¾░ıø</span> {usage}%",
    "tooltip": true,
    "interval": 1,
  },

  "custom/amd_gpu": {
  "exec": "$HOME/dotfiles/scripts/agpucheck.sh",
  "format": "<span color='#c74080'>¾░ıø</span> {}",
  "return-type": "json",
  "interval": 1
  },

  "custom/nvidia_gpu": {
  "exec": "$HOME/dotfiles/scripts/ngpucheck.sh",
  "format": "<span color='#a7c080'>¾░ıø</span> {}",
  "return-type": "json",
  "interval": 1
  },
  "memory": {
    //"format": "¯┐à {}%",
    "format": "<span color='#ffcb6b'>¾░İÜ</span> {}%",
    "interval": 1,
  },

  "temperature": {
    "hwmon-path": "/sys/devices/platform/PNP0C14:02/wmi_bus/wmi_bus-PNP0C14:02/F1DDEE52-063C-4784-A11E-8A06684B9B01/hwmon/hwmon5/temp1_input",
    "critical-threshold": 80,
    "format": "{icon} {temperatureC}┬░C",
    "format-icons": ["¾▒ââ", "¾░öÅ", "¾▒âé"],
  },
}
